# aoe4.hazii.org — WAR ROOM (statische Single-File-App), Apache
#
# Diese Datei zusammen mit der Standalone-HTML (als index.html) in den Docroot
# der Subdomain legen. Sie setzt eine passende Content-Security-Policy für die
# App: inline <style>/<script> sind erlaubt (Single-File-Design). Webfonts sind
# selbst gehostet (in die Datei eingebettet) – kein Google-Fonts-Request.

<IfModule mod_headers.c>
  # Erlaubte externe Ressourcen basieren auf dem tatsächlichen Build:
  #   Bilder: data.aoe4world.com · Fonts/Styles: in die Datei eingebettet (data:)
  #   Statistik: gc.zgo.at (Script) + *.goatcounter.com (Beacon) · Favicon: data:
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'none'; img-src 'self' data: https://data.aoe4world.com https://*.goatcounter.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'unsafe-inline' https://gc.zgo.at; connect-src 'self' https://*.goatcounter.com"
  # Nicht von Suchmaschinen indexieren lassen.
  Header always set X-Robots-Tag "noindex, nofollow"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
</IfModule>

# Übertragung komprimieren – die Single-File wird durch die eingebetteten Fonts
# größer; brotli/gzip drittelt bis halbiert den Transfer für Text-Inhalte.
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript image/svg+xml application/json
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>

# HTML nicht lange cachen, damit neue Releases sofort sichtbar sind. Die
# Sharing-Bilder dürfen dagegen lange gecacht werden.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType image/png "access plus 7 days"
</IfModule>
